# Root deployment notes
# Backend env vars live in Render
# Frontend env vars live in Netlify

# Render backend
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/oppty-chats?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
PORT=10000
FRONTEND_URL=https://your-site.netlify.app

# Optional extra allowed origins
# CORS_ORIGIN=https://deploy-preview-1--your-site.netlify.app

# Netlify frontend
# VITE_API_URL=https://your-backend-name.onrender.com/api
