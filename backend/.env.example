# Backend Environment Variables
# Copy this file to backend/.env for local development

PORT=5000
NODE_ENV=development

# MongoDB Atlas or local MongoDB
MONGODB_URI=mongodb://localhost:27017/oppty-chats

# Change this before deploying
JWT_SECRET=replace-with-a-long-random-secret

# Local frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional extra allowed origins, comma-separated
# CORS_ORIGIN=https://your-site.netlify.app,https://deploy-preview-1--your-site.netlify.app
